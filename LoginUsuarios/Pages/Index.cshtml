@page
@model LoginUsuarios.Pages.IndexModel
@{
    ViewData["Title"] = "Inicio";
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Inicio - LoginUsuarios</title>
    <link rel="stylesheet" href="~/css/Login.css" />
</head>
<body>
    <div class="home-wrapper">
        <div class="home-card">
            <div class="home-icon">&#9989;</div>
            <h1>¡Bienvenido!</h1>

            @if (Model.RegistroExitoso)
            {
                <div class="alert-success alert-success-banner">
                    &#10004;&#65039; ¡Registro exitoso!!!
                </div>
            }

            <p class="user-info">Has iniciado sesión como <strong>@Model.Username</strong></p>
            <p class="user-email">@Model.Email</p>
            <a href="/Account/Logout" class="btn-logout">Cerrar sesión</a>
        </div>
    </div>
</body>
</html>
