@page
@model LoginUsuarios.Pages.Account.ChangePasswordModel
@{
    ViewData["Title"] = "Cambiar Contrasena";
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Cambiar Contrasena - LoginUsuarios</title>
    <link rel="stylesheet" href="~/css/Login.css" />
</head>
<body>
    <div class="login-wrapper">
        <div class="login-card">
            <div class="login-header">
                <div class="login-icon">&#128272;</div>
                <h1>Cambiar contrasena</h1>
                <p>Actualiza tu contrasena de acceso</p>
            </div>

            @* Mostrar mensaje de error si la validacion falla en el PageModel *@
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert-error">&#9888; @Model.ErrorMessage</div>
            }

            @* Mostrar mensaje verde si el cambio fue exitoso *@
            @if (!string.IsNullOrEmpty(Model.SuccessMessage))
            {
                <div class="alert-success">&#10004; @Model.SuccessMessage</div>
            }

            <form method="post">

                @* asp-for vincula el input con la propiedad PasswordActual del PageModel *@
                <div class="form-group">
                    <label asp-for="PasswordActual">Contrasena actual</label>
                    <div class="password-wrapper">
                        <input asp-for="PasswordActual" type="password" id="p1" placeholder="Ingresa tu contrasena actual" required />
                        @* Boton para mostrar/ocultar la contrasena *@
                        <button type="button" class="toggle-pass" onclick="t('p1')">&#128065;</button>
                    </div>
                </div>
                <div class="form-group">
                    <label asp-for="PasswordNueva">Nueva contrasena</label>
                    <div class="password-wrapper">
                        <input asp-for="PasswordNueva" type="password" id="p2" placeholder="Minimo 6 caracteres" required />
                        <button type="button" class="toggle-pass" onclick="t('p2')">&#128065;</button>
                    </div>
                </div>
                <div class="form-group">
                    <label asp-for="ConfirmarPassword">Confirmar nueva contrasena</label>
                    <div class="password-wrapper">
                        <input asp-for="ConfirmarPassword" type="password" id="p3" placeholder="Repite la nueva contrasena" required />
                        <button type="button" class="toggle-pass" onclick="t('p3')">&#128065;</button>
                    </div>
                </div>
                <button type="submit" class="btn-login">Cambiar contrasena</button>
            </form>

            <div class="register-link">
                <a href="/Index">&#8592; Volver al inicio</a>
            </div>
        </div>
    </div>
    <script>function t(id){var i=document.getElementById(id);i.type=i.type==='password'?'text':'password';}</script>
</body>
</html>
