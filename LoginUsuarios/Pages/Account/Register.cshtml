@page
@model LoginUsuarios.Pages.Account.RegisterModel
@{
    ViewData["Title"] = "Registrar Usuario";
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Registro - LoginUsuarios</title>
    <link rel="stylesheet" href="~/css/Login.css" />
</head>
<body>
    <div class="login-wrapper">
        <div class="login-card" style="max-width: 440px;">
            <div class="login-header">
                <div class="login-icon">&#128100;</div>
                <h1>Crear cuenta</h1>
                <p>Completa los datos para registrarte</p>
            </div>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert-error">
                    &#9888; @Model.ErrorMessage
                </div>
            }

            @if (!string.IsNullOrEmpty(Model.SuccessMessage))
            {
                <div class="alert-success">
                    &#10004; @Model.SuccessMessage
                </div>
            }

            <form method="post">
                <div class="form-group">
                    <label asp-for="Nombre">Nombre completo</label>
                    <input asp-for="Nombre"
                           type="text"
                           placeholder="Ingresa tu nombre completo"
                           autocomplete="name"
                           required />
                </div>

                <div class="form-group">
                    <label asp-for="Username">Usuario</label>
                    <input asp-for="Username"
                           type="text"
                           placeholder="Elige un nombre de usuario"
                           autocomplete="username"
                           required />
                </div>

                <div class="form-group">
                    <label asp-for="Email">Correo electrónico</label>
                    <input asp-for="Email"
                           type="email"
                           placeholder="ejemplo@correo.com"
                           autocomplete="email"
                           required />
                </div>

                <div class="form-group">
                    <label asp-for="Password">Contraseña</label>
                    <div class="password-wrapper">
                        <input asp-for="Password"
                               type="password"
                               id="password"
                               placeholder="Crea una contraseña"
                               autocomplete="new-password"
                               required />
                        <button type="button" class="toggle-pass" onclick="togglePass('password')">&#128065;</button>
                    </div>
                </div>

                <div class="form-group">
                    <label asp-for="ConfirmarPassword">Confirmar contraseña</label>
                    <div class="password-wrapper">
                        <input asp-for="ConfirmarPassword"
                               type="password"
                               id="confirmarPassword"
                               placeholder="Repite tu contraseña"
                               autocomplete="new-password"
                               required />
                        <button type="button" class="toggle-pass" onclick="togglePass('confirmarPassword')">&#128065;</button>
                    </div>
                </div>

                <button type="submit" class="btn-login">Registrarme</button>
            </form>

            <div class="register-link">
                ¿Ya tienes cuenta? <a href="/Account/Login">Inicia sesión</a>
            </div>
        </div>
    </div>

    <script>
            function togglePass(id) {
                const input = document.getElementById(id);
                input.type = input.type === 'password' ? 'text' : 'password';
            }
    </script>
</body>
</html>